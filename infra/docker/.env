# Facial Align — Docker Compose Environment
# Development defaults — do NOT use in production

# ── Application ──────────────────────────────────────────────
APP_NAME=facial-align
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=dev-only-change-me-in-production

# ── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql+asyncpg://facial_align:password@postgres:5432/facial_align
DB_HOST=postgres
DB_PORT=5432
DB_NAME=facial_align
DB_USER=facial_align
DB_PASSWORD=password
DATABASE_POOL_SIZE=10

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Object Storage (MinIO) ──────────────────────────────────
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DICOM=dicom-studies
MINIO_BUCKET_MESHES=mesh-assets
MINIO_BUCKET_MODELS=model-registry
MINIO_USE_SSL=false

# ── ML / Inference ───────────────────────────────────────────
MODEL_REGISTRY_PATH=/app/models
INFERENCE_DEVICE=cpu
SEGMENTATION_MODEL=totalsegmentator
DENTAL_MODEL=dental_segmentator
MAX_INFERENCE_BATCH_SIZE=1
INFERENCE_TIMEOUT_SECONDS=300

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# ── HIPAA / Security ────────────────────────────────────────
ENABLE_AUDIT_LOGGING=true
ENABLE_PHI_ENCRYPTION=false
PHI_ENCRYPTION_KEY=dev-only-change-me
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
