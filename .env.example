# Facial Align Environment Configuration
# Copy this to .env and fill in values

# ── Application ──────────────────────────────────────────────
APP_NAME=facial-align
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-string

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://facial_align:password@localhost:5432/facial_align
DATABASE_POOL_SIZE=10

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Object Storage (MinIO / S3) ─────────────────────────────
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DICOM=dicom-studies
MINIO_BUCKET_MESHES=mesh-assets
MINIO_BUCKET_MODELS=model-registry
MINIO_USE_SSL=false

# ── ML / Inference ───────────────────────────────────────────
MODEL_REGISTRY_PATH=/app/models
INFERENCE_DEVICE=cuda:0
# Set to cpu if no GPU available
# INFERENCE_DEVICE=cpu
SEGMENTATION_MODEL=totalsegmentator
DENTAL_MODEL=dental_segmentator
MAX_INFERENCE_BATCH_SIZE=1
INFERENCE_TIMEOUT_SECONDS=300

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── HIPAA / Security ────────────────────────────────────────
ENABLE_AUDIT_LOGGING=true
ENABLE_PHI_ENCRYPTION=true
PHI_ENCRYPTION_KEY=change-me-to-a-256-bit-key
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5

# ── External Services (Optional) ────────────────────────────
# ORTHANC_URL=http://localhost:8042
# OHIF_URL=http://localhost:3000/ohif
